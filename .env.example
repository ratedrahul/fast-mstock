# ---------------------------------------------------------------------------
# MS-Fast environment configuration
# Copy this file to `.env` and fill in the values you need.
# ---------------------------------------------------------------------------

# App
APP_NAME=MS-Fast
DEBUG=false
LOG_LEVEL=INFO

# mStock upstream (defaults are correct for production – usually leave as-is)
MSTOCK_BASE_URL=https://api.mstock.trade
MSTOCK_WS_URL=wss://ws.mstock.trade
MSTOCK_VERSION=1
REQUEST_TIMEOUT=15

# ---------------------------------------------------------------------------
# Credentials
# ---------------------------------------------------------------------------
# MS-Fast is multi-tenant by default: clients send their own credentials per
# request via the `X-Api-Key` and `X-Access-Token` headers.
#
# For single-user / personal deployments you may instead hard-code a default
# credential pair here; it is used whenever the headers are absent.
# MSTOCK_API_KEY=your_api_key_here
# MSTOCK_ACCESS_TOKEN=your_daily_access_token_here

# ---------------------------------------------------------------------------
# Gateway protection (optional but recommended for public deployments)
# ---------------------------------------------------------------------------
# If set, every request (except docs/health) must send `X-Gateway-Key` with
# this value. Leave empty to disable gateway auth.
# GATEWAY_API_KEY=choose-a-long-random-secret

# CORS – comma separated list of allowed origins, or * for all
CORS_ORIGINS=*
