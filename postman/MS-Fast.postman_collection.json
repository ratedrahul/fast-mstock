              { "key": "X-Access-Token", "value": "{{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/regular", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "regular"] },
            "body": { "mode": "raw", "raw": "{\n  \"tradingsymbol\": \"INFY-EQ\",\n  \"exchange\": \"NSE\",\n  \"transaction_type\": \"BUY\",\n  \"order_type\": \"LIMIT\",\n  \"quantity\": 10,\n  \"product\": \"MIS\",\n  \"validity\": \"DAY\",\n  \"price\": 1250,\n  \"trigger_price\": 0,\n  \"disclosed_quantity\": 0\n}" }
          }
        },
        {
          "name": "Modify Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
