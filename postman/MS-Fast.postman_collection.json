{
  "info": {
    "name": "MS-Fast — mStock Trading API Gateway",
    "description": "Full collection for the MS-Fast FastAPI gateway over the mStock Trading API (Type A). Set the collection variables baseUrl, apiKey, accessToken (and gatewayKey if enabled).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "apiKey", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "gatewayKey", "value": "" }
  ],
  "auth": { "type": "noauth" },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (trigger OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"MA1234567\",\n  \"password\": \"Secret@123\"\n}" }
          }
        },
        {
          "name": "Generate Session (OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/session", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "session"] },
            "body": { "mode": "raw", "raw": "{\n  \"api_key\": \"{{apiKey}}\",\n  \"request_token\": \"123456\",\n  \"checksum\": \"L\"\n}" }
          }
        },
        {
          "name": "Verify TOTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/verify-totp", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "verify-totp"] },
            "body": { "mode": "raw", "raw": "{\n  \"api_key\": \"{{apiKey}}\",\n  \"totp\": \"654321\"\n}" }
          }
        },
        {
          "name": "Fund Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Api-Key", "value": "{{apiKey}}" },
              { "key": "X-Access-Token", "value": "{{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/fund-summary", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "fund-summary"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Api-Key", "value": "{{apiKey}}" },
              { "key": "X-Access-Token", "value": "{{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
