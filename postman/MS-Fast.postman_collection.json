            ],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/regular/1000000000016050", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "regular", "1000000000016050"] },
            "body": { "mode": "raw", "raw": "{\n  \"order_type\": \"LIMIT\",\n  \"quantity\": 5,\n  \"price\": 2000,\n  \"validity\": \"DAY\",\n  \"trigger_price\": 0,\n  \"disclosed_quantity\": 0\n}" }
          }
        },
